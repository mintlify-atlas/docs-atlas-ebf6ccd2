{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Tendon Next.js Template",
  "theme": "palm",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#38bdf8",
    "dark": "#0284c7"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Ngineer101/tendon-nextjs-template"
    }
  },
  "footer": {
